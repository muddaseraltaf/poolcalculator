---
import { SITE, NAV } from '../config/site';
const current = Astro.url.pathname;
---

<header
  class="sticky top-0 z-30 border-b border-slate-100 bg-white/95 backdrop-blur"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4"
    aria-label="Primary"
  >
    <a href="/" class="flex items-center gap-2 font-bold text-pool-800">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2C12 2 5 9 5 14a7 7 0 0 0 14 0c0-5-7-12-7-12Z" fill="currentColor"/>
      </svg>
      <span>{SITE.shortName}</span>
    </a>

    <ul class="hidden items-center gap-6 text-sm font-medium md:flex">
      {
        NAV.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={current === item.href ? 'page' : undefined}
              class:list={[
                'transition hover:text-pool-700',
                current === item.href ? 'text-pool-700' : 'text-slate-600',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      id="menu-toggle"
      class="md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>

  <ul
    id="mobile-menu"
    class="hidden border-t border-slate-100 bg-white px-4 py-2 md:hidden"
  >
    {
      NAV.map((item) => (
        <li>
          <a
            href={item.href}
            class="block py-2 text-slate-700 hover:text-pool-700"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
