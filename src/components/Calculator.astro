---
// Interactive pool shock calculator.
// The client script imports the SAME engine module the tests cover, so the
// number a visitor sees equals the number we verified in CI.
import { PRODUCTS, SCENARIOS } from '../lib/shock-engine';

interface Props {
  // Page can lock the calculator to a scenario and/or a product family so each
  // fanned-out page is genuinely configured for its job.
  defaultScenario?: keyof typeof SCENARIOS;
  defaultProduct?: string;
  lockScenario?: boolean;
  lockProduct?: boolean;
  heading?: string;
}

const {
  defaultScenario = 'weekly',
  defaultProduct = 'cal-hypo-68',
  lockScenario = false,
  lockProduct = false,
  heading = 'Shock dose calculator',
} = Astro.props;

const products = Object.values(PRODUCTS);
const scenarios = Object.values(SCENARIOS);
---

<section
  class="rounded-2xl border border-pool-100 bg-white p-5 shadow-sm sm:p-7"
  aria-labelledby="calc-heading"
  data-default-scenario={defaultScenario}
  data-default-product={defaultProduct}
>
  <h2 id="calc-heading" class="text-xl font-bold text-pool-900">{heading}</h2>

  <form id="shock-form" class="mt-5 grid gap-5" novalidate>
    <!-- Volume -->
    <fieldset class="grid gap-2">
      <legend class="text-sm font-semibold text-slate-700">Pool volume</legend>
      <div class="flex flex-wrap items-end gap-3">
        <label class="flex-1">
          <span class="mb-1 block text-xs text-slate-500">Volume (US gallons)</span>
          <input
            type="number" inputmode="numeric" name="volume" id="volume"
            min="1" step="1" placeholder="e.g. 15000" required
            class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-pool-500 focus:ring-2 focus:ring-pool-200 focus:outline-none"
          />
        </label>
        <button type="button" id="vol-helper-toggle"
          class="rounded-lg border border-pool-200 px-3 py-2 text-sm text-pool-700 hover:bg-pool-50">
          Don't know it?
        </button>
      </div>

      <!-- Volume-from-dimensions helper (progressive enhancement) -->
      <div id="vol-helper" class="hidden rounded-lg bg-pool-50 p-3">
        <div class="grid gap-3 sm:grid-cols-2">
          <label>
            <span class="mb-1 block text-xs text-slate-500">Shape</span>
            <select id="shape" class="w-full rounded-lg border border-slate-300 px-3 py-2">
              <option value="rectangle">Rectangle</option>
              <option value="round">Round</option>
              <option value="oval">Oval</option>
            </select>
          </label>
          <label>
            <span class="mb-1 block text-xs text-slate-500">Average depth (ft)</span>
            <input type="number" id="avgDepth" min="0" step="0.1" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
          </label>
          <label data-dim="length-width">
            <span class="mb-1 block text-xs text-slate-500">Length (ft)</span>
            <input type="number" id="length" min="0" step="0.1" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
          </label>
          <label data-dim="length-width">
            <span class="mb-1 block text-xs text-slate-500">Width (ft)</span>
            <input type="number" id="width" min="0" step="0.1" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
          </label>
          <label data-dim="diameter" class="hidden">
            <span class="mb-1 block text-xs text-slate-500">Diameter (ft)</span>
            <input type="number" id="diameter" min="0" step="0.1" class="w-full rounded-lg border border-slate-300 px-3 py-2" />
          </label>
        </div>
        <button type="button" id="vol-apply"
          class="mt-3 rounded-lg bg-pool-600 px-3 py-2 text-sm font-medium text-white hover:bg-pool-700">
          Use this volume
        </button>
      </div>
    </fieldset>

    <!-- Scenario -->
    <label class:list={[lockScenario && 'hidden']}>
      <span class="mb-1 block text-sm font-semibold text-slate-700">Situation</span>
      <select name="scenario" id="scenario"
        class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-pool-500 focus:ring-2 focus:ring-pool-200 focus:outline-none">
        {scenarios.map((s) => (
          <option value={s.id} selected={s.id === defaultScenario}>
            {s.label} (target {s.targetFc} ppm)
          </option>
        ))}
      </select>
    </label>

    <!-- Product -->
    <label class:list={[lockProduct && 'hidden']}>
      <span class="mb-1 block text-sm font-semibold text-slate-700">Shock product</span>
      <select name="product" id="product"
        class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-pool-500 focus:ring-2 focus:ring-pool-200 focus:outline-none">
        {products.map((p) => (
          <option value={p.id} selected={p.id === defaultProduct}>{p.label}</option>
        ))}
      </select>
    </label>

    <!-- Optional current readings -->
    <details class="rounded-lg border border-slate-200 p-3">
      <summary class="cursor-pointer text-sm font-medium text-pool-700">
        Add test readings for a precise breakpoint dose (optional)
      </summary>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <label>
          <span class="mb-1 block text-xs text-slate-500">Free chlorine (ppm)</span>
          <input type="number" name="fc" id="fc" min="0" step="0.1"
            class="w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
        <label>
          <span class="mb-1 block text-xs text-slate-500">Total chlorine (ppm)</span>
          <input type="number" name="tc" id="tc" min="0" step="0.1"
            class="w-full rounded-lg border border-slate-300 px-3 py-2" />
        </label>
      </div>
      <p class="mt-2 text-xs text-slate-500">
        Combined chlorine = total − free. We target 10× combined chlorine to hit
        breakpoint, or your situation's level, whichever is higher.
      </p>
    </details>

    <button type="submit"
      class="rounded-xl bg-pool-700 px-5 py-3 text-base font-semibold text-white transition hover:bg-pool-800 focus:ring-2 focus:ring-pool-300 focus:outline-none">
      Calculate shock dose
    </button>
  </form>

  <!-- Result region: aria-live so screen readers announce updates -->
  <div id="result" class="mt-6 hidden" role="region" aria-live="polite" aria-label="Result"></div>
  <p id="error" class="mt-4 hidden rounded-lg bg-red-50 p-3 text-sm text-red-700" role="alert"></p>
</section>

<script>
  import { calculateShock, poolVolumeGallons, PRODUCTS } from '../lib/shock-engine';

  const form = document.getElementById('shock-form') as HTMLFormElement | null;
  if (form) {
    const $ = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
    const resultEl = document.getElementById('result')!;
    const errorEl = document.getElementById('error')!;

    // Volume-from-dimensions helper
    const helper = document.getElementById('vol-helper')!;
    document.getElementById('vol-helper-toggle')?.addEventListener('click', () => {
      helper.classList.toggle('hidden');
    });
    const shapeSel = $('shape') as HTMLSelectElement | null;
    const syncShape = () => {
      const shape = shapeSel?.value;
      document.querySelectorAll<HTMLElement>('[data-dim="length-width"]').forEach((el) =>
        el.classList.toggle('hidden', shape === 'round')
      );
      document.querySelector<HTMLElement>('[data-dim="diameter"]')?.classList.toggle('hidden', shape !== 'round');
    };
    shapeSel?.addEventListener('change', syncShape);
    syncShape();
    document.getElementById('vol-apply')?.addEventListener('click', () => {
      const shape = (shapeSel?.value || 'rectangle') as 'rectangle' | 'round' | 'oval';
      const num = (id: string) => parseFloat(($(id) as HTMLInputElement)?.value || '0') || 0;
      const gal = poolVolumeGallons(shape, {
        length: num('length'), width: num('width'),
        diameter: num('diameter'), avgDepth: num('avgDepth'),
      });
      if (gal > 0) {
        ($('volume') as HTMLInputElement).value = String(gal);
        helper.classList.add('hidden');
      }
    });

    const fmt = (n: number) => n.toLocaleString('en-US', { maximumFractionDigits: 2 });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const volume = parseFloat(($('volume') as HTMLInputElement).value);
      if (!volume || volume <= 0) {
        errorEl.textContent = 'Enter your pool volume in gallons (or use the helper to estimate it).';
        errorEl.classList.remove('hidden');
        return; // inputs are preserved — we never clear the form on error
      }

      const productId = ($('product') as HTMLSelectElement).value;
      const scenario = ($('scenario') as HTMLSelectElement).value as any;
      const fcRaw = ($('fc') as HTMLInputElement).value;
      const tcRaw = ($('tc') as HTMLInputElement).value;

      const r = calculateShock({
        volumeGallons: volume,
        productId,
        scenario,
        currentFc: fcRaw ? parseFloat(fcRaw) : undefined,
        totalChlorine: tcRaw ? parseFloat(tcRaw) : undefined,
      });

      const form2 = PRODUCTS[productId].form;
      let amount = '';
      if (form2 === 'granular') {
        amount = `<strong class="text-2xl text-pool-900">${fmt(r.pounds!)} lb</strong>
          <span class="text-slate-500">(${fmt(r.ounces!)} oz · about ${fmt(r.cups!)} cups)</span>`;
      } else {
        amount = `<strong class="text-2xl text-pool-900">${fmt(r.flOunces!)} fl oz</strong>
          <span class="text-slate-500">(${fmt(r.gallons!)} gal)</span>`;
      }

      const bp = r.breakpointFc != null
        ? `<li>Combined chlorine ${fmt(r.combinedChlorine!)} ppm → breakpoint target ${fmt(r.breakpointFc)} ppm.</li>` : '';
      const warnings = r.warnings.length
        ? `<ul class="mt-3 space-y-1 text-sm text-amber-700">${r.warnings.map((w) => `<li>⚠ ${w}</li>`).join('')}</ul>` : '';

      resultEl.innerHTML = `
        <div class="rounded-xl bg-pool-50 p-5">
          <p class="text-sm font-medium text-pool-700">Add about</p>
          <p class="mt-1">${amount}</p>
          <p class="mt-1 text-sm text-slate-600">of ${r.productLabel} to reach ${fmt(r.targetFc)} ppm free chlorine (raising it ${fmt(r.deltaFc)} ppm).</p>
          <ul class="mt-3 space-y-1 text-sm text-slate-600">
            ${bp}
            <li>${r.waitToSwim}</li>
          </ul>
          ${warnings}
        </div>`;
      resultEl.classList.remove('hidden');
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  }
</script>
