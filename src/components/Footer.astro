---
import { SITE, FOOTER_LINKS } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-slate-100 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="flex flex-col gap-6 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <p class="font-bold text-pool-800">{SITE.name}</p>
        <p class="mt-2 text-sm text-slate-600">{SITE.tagline}</p>
        <p class="mt-2 text-sm text-slate-500">
          Estimates for informational use only. Always follow the safety and
          dosing instructions on your chemical product label.
        </p>
      </div>
      <nav aria-label="Footer">
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
          {
            FOOTER_LINKS.map((l) => (
              <li>
                <a href={l.href} class="text-slate-600 hover:text-pool-700">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <div
      class="mt-8 flex flex-col gap-2 border-t border-slate-200 pt-6 text-xs text-slate-500 md:flex-row md:justify-between"
    >
      <p>© {year} {SITE.name}. Maintained by {SITE.publisher}.</p>
      <p>
        Questions or corrections:
        <a href={`mailto:${SITE.email}`} class="underline hover:text-pool-700"
          >{SITE.email}</a
        >
      </p>
    </div>
  </div>
</footer>
