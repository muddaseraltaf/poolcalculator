---
import BaseLayout from './BaseLayout.astro';
import Calculator from '../components/Calculator.astro';
import AdSlot from '../components/AdSlot.astro';
import SourcesBlock from '../components/SourcesBlock.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { SITE } from '../config/site';
import type { SCENARIOS } from '../lib/shock-engine';

// Enforces the page anatomy: H1 → value line → calculator above the fold →
// (result renders inside calculator) → unique body → formula → sources →
// limitations → FAQ → footer. Ads/affiliate only appear after the result.
interface Props {
  title: string; // becomes the <h1> and part of <title>
  metaTitle?: string; // optional distinct SEO title
  description: string;
  valueLine: string; // one-sentence promise under the H1
  calcHeading?: string;
  defaultScenario?: keyof typeof SCENARIOS;
  defaultProduct?: string;
  lockScenario?: boolean;
  lockProduct?: boolean;
  breadcrumbs?: { name: string; url: string }[];
  faq?: { question: string; answer: string }[];
}

const {
  title, metaTitle, description, valueLine,
  calcHeading, defaultScenario, defaultProduct,
  lockScenario, lockProduct, breadcrumbs, faq,
} = Astro.props;
---

<BaseLayout
  title={metaTitle ?? title}
  description={description}
  isTool={true}
  breadcrumbs={breadcrumbs}
  faq={faq}
>
  <div class="mx-auto max-w-3xl px-4 py-8 sm:py-10">
    {breadcrumbs && (
      <nav aria-label="Breadcrumb" class="mb-4 text-xs text-slate-500">
        <ol class="flex flex-wrap gap-1">
          {breadcrumbs.map((b, i) => (
            <li>
              {i > 0 && <span class="mx-1">/</span>}
              {i < breadcrumbs.length - 1
                ? <a href={new URL(b.url).pathname} class="hover:text-pool-700">{b.name}</a>
                : <span>{b.name}</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <h1 class="text-3xl font-bold text-pool-900 sm:text-4xl">{title}</h1>
    <p class="mt-3 text-lg text-slate-600">{valueLine}</p>

    <!-- Calculator above the fold; result panel lives inside it -->
    <div class="mt-8">
      <Calculator
        heading={calcHeading ?? 'Shock dose calculator'}
        defaultScenario={defaultScenario}
        defaultProduct={defaultProduct}
        lockScenario={lockScenario}
        lockProduct={lockProduct}
      />
    </div>

    <!-- Ad slot only AFTER the result region -->
    <AdSlot slot="below-result" />

    <!-- Unique, page-specific explanatory content -->
    <article class="prose-psc mt-10 space-y-6 text-slate-700">
      <slot />
    </article>

    <!-- Optional formula / worked example provided by the page -->
    <slot name="formula" />

    <!-- Optional next-action product suggestions -->
    <slot name="products" />

    <!-- Optional FAQ visible text (schema is emitted separately when faq prop set) -->
    {faq && faq.length > 0 && (
      <section class="mt-10">
        <h2 class="text-xl font-bold text-pool-900">Frequently asked questions</h2>
        <dl class="mt-4 space-y-4">
          {faq.map((f) => (
            <div class="rounded-lg border border-slate-200 p-4">
              <dt class="font-semibold text-slate-800">{f.question}</dt>
              <dd class="mt-1 text-sm text-slate-600">{f.answer}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <SourcesBlock />
    <Disclaimer />
  </div>
</BaseLayout>

<style>
  .prose-psc :global(h2) { font-size: 1.4rem; font-weight: 700; color: var(--color-pool-900); margin-top: 1.5rem; }
  .prose-psc :global(h3) { font-size: 1.1rem; font-weight: 600; color: var(--color-pool-800); margin-top: 1rem; }
  .prose-psc :global(p) { margin-top: .5rem; line-height: 1.7; }
  .prose-psc :global(ul) { margin-top: .5rem; list-style: disc; padding-left: 1.25rem; }
  .prose-psc :global(li) { margin-top: .25rem; }
  .prose-psc :global(a) { color: var(--color-pool-700); text-decoration: underline; }
  .prose-psc :global(table) { width: 100%; margin-top: 1rem; border-collapse: collapse; font-size: .9rem; }
  .prose-psc :global(th), .prose-psc :global(td) { border: 1px solid var(--color-slate-200, #e2e8f0); padding: .5rem .75rem; text-align: left; }
  .prose-psc :global(th) { background: var(--color-pool-50); }
</style>
