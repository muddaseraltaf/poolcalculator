---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { SITE } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Reading time from raw word count (~200 wpm), floored at 1.
const words = post.body?.trim().split(/\s+/).length ?? 0;
const readingMinutes = Math.max(1, Math.round(words / 200));

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Blog', url: `${SITE.url}/blog/` },
  { name: post.data.title, url: `${SITE.url}/blog/${post.id}/` },
];
---
<BlogPost
  title={post.data.title}
  description={post.data.description}
  publishDate={post.data.publishDate}
  updatedDate={post.data.updatedDate}
  relatedTool={post.data.relatedTool}
  relatedToolLabel={post.data.relatedToolLabel}
  readingMinutes={readingMinutes}
  breadcrumbs={breadcrumbs}
>
  <Content />
</BlogPost>
