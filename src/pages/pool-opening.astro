---
import ToolPage from '../layouts/ToolPage.astro';
import FormulaBlock from '../components/FormulaBlock.astro';
import ProductRecommendation from '../components/ProductRecommendation.astro';
import { SITE } from '../config/site';

const breadcrumbs = [
  { name: 'Home', url: `${SITE.url}/` },
  { name: 'Pool Opening', url: `${SITE.url}/pool-opening/` },
];

const faq = [
  {
    question: 'How much shock to open a pool for the season?',
    answer:
      'A season opening typically targets about 15 ppm free chlorine to knock back anything that grew over winter. With cal-hypo 73% that is roughly 2 lb per 10,000 gallons. Enter your volume above for the exact amount, and re-shock if the water is green or cloudy after the first dose.',
  },
  {
    question: 'What order do I do things when opening a pool?',
    answer:
      'Remove and clean the cover, top up the water, reconnect and prime the equipment, run the pump, then test and balance pH and alkalinity before shocking. Balancing first makes the opening shock far more effective.',
  },
  {
    question: 'Should I shock immediately when opening?',
    answer:
      'Balance pH and alkalinity first, then shock. Shocking into unbalanced, high-pH water wastes chlorine. Once balanced, add the opening dose at dusk and run the filter continuously for at least 24 hours.',
  },
];
---

<ToolPage
  title="Pool Opening Shock Calculator"
  metaTitle="Pool Opening Shock Calculator — Season Startup Dose"
  description="Opening your pool for the season? Enter your volume for the exact startup shock dose, plus the right order of steps to get from cover-off to swim-ready."
  valueLine="Opening for the season? Get the exact startup dose to reach ~15 ppm and clear whatever grew over winter."
  calcHeading="How much shock to open my pool?"
  defaultScenario="opening"
  defaultProduct="cal-hypo-73"
  breadcrumbs={breadcrumbs}
  faq={faq}
>
  <h2>Start the season with a strong reset</h2>
  <p>
    After months under a cover, water is stale and low on sanitizer, and there’s
    almost always some algae or organic buildup even if the water looks clear. An
    opening shock of about 15 ppm resets the pool and gives your regular sanitizer
    a clean slate for the season.
  </p>

  <h2>The right order of operations</h2>
  <p>
    Sequence matters at opening — do these in order for the best result:
  </p>
  <ul>
    <li><strong>Clean the cover and remove it</strong> without dumping debris into the water.</li>
    <li><strong>Top up to normal level</strong> and reconnect, prime, and start the equipment.</li>
    <li><strong>Test and balance</strong> pH to 7.2–7.6 and total alkalinity to 80–120 ppm.</li>
    <li><strong>Shock to ~15 ppm</strong> using the dose below, ideally at dusk.</li>
    <li><strong>Filter 24+ hours</strong>, then re-test; if the water is green or cloudy, move to the matching calculator.</li>
  </ul>

  <h2>If it opens green or cloudy</h2>
  <p>
    A pool that wintered poorly may open green or hazy. Don’t just repeat the
    opening dose — switch to the
    <a href="/green-pool/">green pool</a> or
    <a href="/cloudy-pool/">cloudy pool</a> target, which are higher and matched to
    those problems.
  </p>

  <FormulaBlock
    slot="formula"
    example={{
      context: 'Example: an 18,000-gallon pool opening for summer with cal-hypo 73%.',
      steps: [
        'Opening target is about 15 ppm free chlorine; assume current FC ≈ 0.',
        'Raise needed = 15 ppm.',
        'Pure chlorine ≈ 8.5e-6 lb × 15 × 18,000 = 2.3 lb.',
        'Product = 2.3 ÷ 0.73 ≈ 3.15 lb of cal-hypo 73%.',
      ],
      answer: 'Add about 3.15 lb of cal-hypo 73% after balancing, then filter 24 hours and re-test.',
    }}
  />

  <ProductRecommendation
    slot="products"
    items={[
      { name: 'Cal-hypo 73% shock', note: 'Powerful startup shock for a clean seasonal reset.', searchTerm: 'cal hypo pool shock 73%' },
      { name: 'Alkalinity & pH balancers', note: 'Balance before shocking so the chlorine works fully.', searchTerm: 'pool alkalinity increaser ph balancer' },
      { name: 'Pool opening / startup kit', note: 'Bundles the chemicals a season opening typically needs.', searchTerm: 'pool opening startup chemical kit' },
    ]}
  />
</ToolPage>
